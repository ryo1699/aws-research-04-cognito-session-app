project_name = "aws-research-04-cognito-session-app"
aws_region   = "ap-northeast-1"

# Cognito email MFA requires a verified SES identity when email_sending_account is DEVELOPER.
ses_from_email = "no-reply@example.com"
ses_source_arn = "arn:aws:ses:ap-northeast-1:123456789012:identity/no-reply@example.com"

api_cors_allowed_origins = ["http://localhost:3000"]
password_minimum_length  = 12
